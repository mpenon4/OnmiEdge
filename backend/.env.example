# Port the Hono server listens on (default 3001)
PORT=3001

# Comma-separated list of allowed origins for direct (non-proxied) browser calls.
# When the frontend uses the Next.js rewrite, CORS is bypassed.
CORS_ORIGIN=http://localhost:3000

# Optional: AI Gateway key. Only needed if not using zero-config providers
# (OpenAI, Anthropic, Google Vertex, AWS Bedrock, Fireworks).
# AI_GATEWAY_API_KEY=
