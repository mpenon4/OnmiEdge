{
  "name": "omniedge-root",
  "version": "0.1.0",
  "private": true,
  "description": "Root delegate so the v0 preview boots the Next.js app that lives in /frontend. Vercel deploys still use their own Root Directory setting and ignore this file.",
  "scripts": {
    "postinstall": "cd frontend && npm install --no-audit --no-fund --silent",
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd frontend && npm run start",
    "lint": "cd frontend && npm run lint"
  },
  "dependencies": {
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-resizable-panels": "^4.10.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  }
}
