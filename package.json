{
  "name": "omniedge-studio-root",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"magenta,cyan\" \"pnpm --filter @omniedge/backend dev\" \"pnpm --filter @omniedge/frontend dev\"",
    "build": "pnpm --filter @omniedge/frontend build && pnpm --filter @omniedge/backend build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}