{
  "name": "omniedge",
  "version": "0.1.0",
  "private": true,
  "description": "OmniEdge Studio monorepo — frontend (Next.js) + backend (Hono + AI SDK).",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"pnpm --filter @omniedge/backend dev\" \"pnpm --filter @omniedge/frontend dev\"",
    "dev:frontend": "pnpm --filter @omniedge/frontend dev",
    "dev:backend": "pnpm --filter @omniedge/backend dev",
    "build": "pnpm --recursive build",
    "build:frontend": "pnpm --filter @omniedge/frontend build",
    "build:backend": "pnpm --filter @omniedge/backend build",
    "start": "concurrently --kill-others-on-fail --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"pnpm --filter @omniedge/backend start\" \"pnpm --filter @omniedge/frontend start\"",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
