# =============================================================================
# OmniEdge Studio — root env example
# =============================================================================
# Copy to .env.local for local development.

# -----------------------------------------------------------------------------
# Frontend (read by frontend/next.config.mjs at build time)
# -----------------------------------------------------------------------------
# URL where the backend is reachable. Used by the server-side /api/* rewrite
# in next.config.mjs. Local dev defaults to http://localhost:3001.
# In production set this to the public URL of the deployed backend.
BACKEND_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Backend (read by backend/src/server.ts and the AI SDK)
# -----------------------------------------------------------------------------
PORT=3001
CORS_ORIGIN=http://localhost:3000
# AI_GATEWAY_API_KEY=
